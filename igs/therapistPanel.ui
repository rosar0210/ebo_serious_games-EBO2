    <bool>true</bool>
   </property>
   <property name="html">
    <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Ubuntu Mono'; font-size:20pt; font-weight:600; font-style:normal;&quot; bgcolor=&quot;#ffffff&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:14pt; font-style:italic; text-decoration: underline; color:#77767b;&quot;&gt;Controles de sesión&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-size:14pt; color:#26a269;&quot;&gt;Comenzar/Parar:&lt;/span&gt;&lt;span style=&quot; font-size:14pt;&quot;&gt; Controlan el cronómetro de la sesión con cada paciente. Pulsar &lt;/span&gt;&lt;span style=&quot; font-size:14pt; text-decoration: underline; color:#000000;&quot;&gt;Comenzar&lt;/span&gt;&lt;span style=&quot; font-size:14pt;&quot;&gt; para empezar a registrar y &lt;/span&gt;&lt;span style=&quot; font-size:14pt; text-decoration: underline; color:#000000;&quot;&gt;Parar&lt;/span&gt;&lt;span style=&quot; font-size:14pt;&quot;&gt; para registrar al usuario.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:14pt; color:#000000;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-size:14pt; color:#26a269;&quot;&gt;Cerrar (X):&lt;/span&gt;&lt;span style=&quot; font-size:14pt;&quot;&gt; Finaliza la jornada registrando el centro.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-size:14pt;&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; font-style:italic; text-decoration: underline; color:#77767b;&quot;&gt;Grupo Botones 1&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; color:#26a269;&quot;&gt;Atención/Pausa Larga/Distracción: &lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;Contabiliza el tiempo que el usuario está en enfocado en el robot, pierde el foco o permanece presente pero no responde.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; font-style:italic; text-decoration: underline; color:#77767b;&quot;&gt;Grupo Botones 2&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; color:#26a269;&quot;&gt;Respuesta Autónoma/Necesidad de Ayuda:&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt; Contabiliza el tiempo que el usuario responde sin intervención o necesita ayuda del terapeuta para completar la tarea.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;&lt;br /&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; font-style:italic; text-decoration: underline; color:#77767b;&quot;&gt;Grupo Botones 3 (Contadores)&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; color:#26a269;&quot;&gt;Frustración:&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt; el usuario está enfadado, rechaza al robot o quiere abandonar.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; color:#26a269;&quot;&gt;Dificultad de comprensión:&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt; el usuario no entiende el juego o al robot.&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt; color:#26a269;&quot;&gt;Afecto positivo:&lt;/span&gt;&lt;span style=&quot; font-family:'Ubuntu Mono','Ubuntu Mono'; font-size:14pt;&quot;&gt; el usuario responde de manera muy entusiasta ante el juego o el robot.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
   </property>
  </widget>
